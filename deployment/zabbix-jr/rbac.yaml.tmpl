---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: zabbix
  namespace: {{ .kapp_namespace }}
rules:
- apiGroups:
  - ""
  resources:
  - pods
  - services
  - endpoints
  - events
  verbs:
  - get
  - list
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: zabbix
  namespace: {{ .kapp_namespace }}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: zabbix
subjects:
- kind: ServiceAccount
  name: zabbix
  namespace: {{ .kapp_namespace }}
